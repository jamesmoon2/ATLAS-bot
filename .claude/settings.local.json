{
  "permissions": {
    "allow": [
      "Bash",
      "Edit",
      "Write",
      "Read",
      "WebSearch",
      "WebFetch(domain:publish.obsidian.md)",
      "Bash(tmux capture-pane:*)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "mcp__google_bot__*",
      "mcp__garmin__*",
      "mcp__whoop__*"
    ],
    "deny": [
      "Bash(rm:*)",
      "Bash(rmdir:*)",
      "Bash(chmod:*)",
      "Bash(chown:*)",
      "Bash(dd:*)",
      "Bash(mkfs:*)",
      "Bash(shutdown:*)",
      "Bash(reboot:*)"
    ]
  },
  "enabledMcpjsonServers": ["garmin", "weather", "google_bot", "oura", "whoop"],
  "disabledMcpjsonServers": [],
  "enableAllProjectMcpServers": true
}
