# Discord Bot Token (from Discord Developer Portal)
DISCORD_TOKEN=your_discord_bot_token_here

# Legacy Discord channel ID fallback for send_message.py
DISCORD_CHANNEL_ID=your_channel_id_here

# Channel-specific Discord channel IDs (recommended for production rename safety)
ATLAS_CHANNEL_ID_ATLAS=your_atlas_channel_id_here
ATLAS_CHANNEL_ID_HEALTH=your_health_channel_id_here
ATLAS_CHANNEL_ID_PROJECTS=your_projects_channel_id_here
ATLAS_CHANNEL_ID_BRIEFINGS=your_briefings_channel_id_here
ATLAS_CHANNEL_ID_ATLAS_DEV=your_atlas_dev_channel_id_here

# Optional auto-activation allowlist. If unset, all channels in channel_configs.py activate.
# ATLAS_CONFIGURED_CHANNELS=atlas,health,projects,briefings,atlas-dev

# Legacy webhook fallback for cron job notifications
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_here

# Channel-specific Discord webhooks for cron job notifications
DISCORD_WEBHOOK_ATLAS=https://discord.com/api/webhooks/your_atlas_webhook_here
DISCORD_WEBHOOK_HEALTH=https://discord.com/api/webhooks/your_health_webhook_here
DISCORD_WEBHOOK_PROJECTS=https://discord.com/api/webhooks/your_projects_webhook_here
DISCORD_WEBHOOK_BRIEFINGS=https://discord.com/api/webhooks/your_briefings_webhook_here
DISCORD_WEBHOOK_ATLAS_DEV=https://discord.com/api/webhooks/your_atlas_dev_webhook_here

# Paths (customize for your setup)
VAULT_PATH=/path/to/your/vault
SESSIONS_DIR=./sessions
BOT_DIR=/path/to/atlas-bot
SYSTEM_PROMPT_PATH=/path/to/your/vault/System/claude.md
CONTEXT_PATH=/path/to/your/vault/System/ATLAS-Context.md
TASKS_FILE_PATH=/path/to/your/vault/1. Tasks.md

# Agent harness selection
# claude = Anthropic Claude Code CLI
# codex = OpenAI Codex CLI
ATLAS_AGENT_PROVIDER=claude

# Optional model defaults by provider
ATLAS_CLAUDE_MODEL=opus
ATLAS_CODEX_MODEL=gpt-5.4

# Optional Codex tuning
# low, medium, high, xhigh
ATLAS_CODEX_REASONING_EFFORT=xhigh

# Optional dedicated Codex profile/home for the bot
# If unset, Codex uses the current environment's CODEX_HOME/default profile
# Recommended when the bot should keep its own Gmail/Google Calendar connector state
# ATLAS_CODEX_HOME=/path/to/bot-specific-codex-home

# Garmin Connect (auth via: python mcp-servers/garmin/oauth_setup.py)
# Tokens resolve from mcp-servers/credentials/garminconnect first, then ~/.garminconnect
